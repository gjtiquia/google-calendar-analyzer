package partials

import (
	"time"

	"github.com/gjtiquia/google-calendar-analyzer/internal/calendar"
)

templ EventsResult(summary calendar.EventSummary, events []calendar.Event, loc *time.Location) {
	<div class="flex flex-col gap-8">
		@EventsSummary(summary)
		@EventsTable(events, loc)
	</div>
}
