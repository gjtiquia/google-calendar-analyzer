APP_ENV=development
APP_ADDR=:8080
# Public base URL used for OAuth redirects (no trailing slash). For local dev:
APP_BASE_URL=http://localhost:8080

# At least 32 bytes. Base64 or a long random string.
SESSION_SECRET=replace-with-openssl-rand-base64-32

SESSION_COOKIE_NAME=gca_session
SESSION_MAX_AGE_SECONDS=3600

# Google Cloud OAuth 2.0 Client (Desktop or Web). Authorized redirect URI must match GOOGLE_REDIRECT_URL exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
